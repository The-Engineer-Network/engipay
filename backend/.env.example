# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration
DB_NAME=engipay_db
DB_USER=engipay_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_SSL=false
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Blockchain RPC URLs - Backend Dev 1
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
STARKNET_RPC_URL=https://rpc.starknet.lava.build
STARKNET_NETWORK=sepolia
BITCOIN_RPC_URL=https://blockchain.info

# Alternative RPC Providers
# ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
# ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Price Feed APIs
COINGECKO_API_KEY=optional_for_higher_rate_limits

# DeFi Protocol APIs (Backend Dev 2)
VESU_API_KEY=your_vesu_api_key
TROVE_API_KEY=your_trove_api_key
ENDURFI_API_KEY=your_endurfi_api_key

# Cross-Chain Integration (Backend Dev 3)
# Atomiq SDK does NOT require API keys - it's fully decentralized
# Optional: Custom pricing API URL (not required)
# ATOMIQ_PRICING_API=https://api.atomiq.exchange/pricing
# Optional: Custom Bitcoin RPC URL (not required)
# BITCOIN_RPC_URL=https://mempool.space/api

# Notification Services (Backend Dev 4)
SENDGRID_API_KEY=your_sendgrid_api_key
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Smart Contract Addresses (Update after deployment)
ESCROW_CONTRACT_ADDRESS=0x0
ENGI_TOKEN_ADDRESS=0x0
REWARD_DISTRIBUTOR_ADDRESS=0x0

# StarkNet Account (for backend transactions)
STARKNET_ACCOUNT_ADDRESS=0x0
STARKNET_PRIVATE_KEY=0x0

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info
LOG_FILE=logs/engipay.log

# ChipiPay Configuration
NEXT_PUBLIC_CHIPIPAY_API_KEY=pk_prod_15642cd599f907c1b4c204028dfdd1c0
CHIPIPAY_SECRET_KEY=sk_prod_8e503e17dd6d5f08fe6d43d22862fda7a03fefab8e102edabf085922a56eb316
CHIPIPAY_WEBHOOK_SECRET=your_chipipay_webhook_secret
CHIPIPAY_API_URL=https://api.chipipay.com/v1


# Tongo SDK Configuration - Privacy-Shielded Transactions
# Official Tongo contracts deployed on StarkNet
# Source: https://docs.tongo.cash/protocol/contracts.html

# Tongo Class Hash (for deployment)
TONGO_CLASS_HASH=0x00582609087e5aeb75dc25284cf954e2cee6974568d1b5636052a9d36eec672a

# Sepolia Testnet Contracts
TONGO_STRK_CONTRACT=0x408163bfcfc2d76f34b444cb55e09dace5905cf84c0884e4637c2c0f06ab6ed
TONGO_ETH_CONTRACT=0x2cf0dc1d9e8c7731353dd15e6f2f22140120ef2d27116b982fa4fed87f6fef5
TONGO_USDC_CONTRACT=0x2caae365e67921979a4e5c16dd70eaa5776cfc6a9592bcb903d91933aaf2552

